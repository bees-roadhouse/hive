{
  "name": "hive-memory",
  "description": "Use Hive as the Hermes memory provider for session-start recall and durable AI journal memory.",
  "env": {
    "HIVE_API_URL": "https://hive.example.com",
    "HIVE_API_TOKEN": "hive_pat_...",
    "HIVE_IDENTITY": "pia",
    "HIVE_PEER": "nate"
  },
  "install": {
    "copy": "plugins/hermes-hive-memory",
    "to": "~/.hermes/plugins/memory/hive",
    "selectProvider": "hive"
  },
  "providerConfig": {
    "base_url": "https://hive.example.com",
    "identity": "pia",
    "peer": "nate",
    "recall_budget": 1500,
    "recall_threshold": 0.72
  }
}
