{
  "description": "Inject Hive session memory at Claude Code startup and capture the transcript into Hive Conversations at session end.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks-handlers/session-start.mjs\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks-handlers/session-end.mjs\""
          }
        ]
      }
    ]
  }
}
