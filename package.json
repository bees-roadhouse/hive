{
  "name": "hive-node",
  "private": true,
  "version": "0.2.0",
  "description": "A fun Node.js + Solid.js rewrite of hive — the shared state (tasks, journal, notes, search) for the Bee's Roadhouse AI configs.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @hive/api --filter @hive/web dev",
    "dev:api": "pnpm --filter @hive/api dev",
    "dev:web": "pnpm --filter @hive/web dev",
    "worker": "pnpm --filter @hive/worker start",
    "worker:once": "pnpm --filter @hive/worker once",
    "build": "pnpm --filter @hive/shared build && pnpm -r --filter @hive/api --filter @hive/web --filter @hive/cli --filter @hive/worker build",
    "seed": "pnpm --filter @hive/api seed",
    "import": "pnpm --filter @hive/api import",
    "hive": "pnpm --filter @hive/cli start --"
  },
  "packageManager": "pnpm@11.5.0"
}
