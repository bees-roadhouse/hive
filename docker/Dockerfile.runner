# syntax=docker/dockerfile:1

# hive-runner — drives hosted Claude Code sessions. It claims `provisioning`
# workspaces from hive-api, provisions an isolated sandbox (git init), runs
# Claude Code via the Claude Agent SDK (which bundles the Claude Code CLI), and
# streams the full transcript back to hive-api. git is needed at RUNTIME for the
# per-session sandbox init; the Agent SDK pulls its own CLI + ripgrep at install.

# ----- deps: same workspace install as the other Node images -----
FROM node:22-bookworm-slim AS deps
RUN corepack enable
WORKDIR /app
RUN printf 'node-linker=hoisted\n' > .npmrc
RUN apt-get update && apt-get install -y --no-install-recommends \
      python3 build-essential \
  && rm -rf /var/lib/apt/lists/*
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json ./
COPY packages/shared/package.json ./packages/shared/
COPY packages/api/package.json ./packages/api/
COPY packages/cli/package.json ./packages/cli/
COPY packages/web/package.json ./packages/web/
COPY packages/worker/package.json ./packages/worker/
COPY packages/agent/package.json ./packages/agent/
COPY packages/runner/package.json ./packages/runner/
RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    pnpm install --frozen-lockfile
COPY . .

# ----- runtime -----
FROM node:22-bookworm-slim AS runtime
ENV NODE_ENV=production
# git: per-session sandbox init. ca-certificates: TLS to the Anthropic API.
RUN apt-get update && apt-get install -y --no-install-recommends \
      git ca-certificates \
  && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY --from=deps /app /app
# Default sandbox root; the deployment mounts a named volume here. The hive-api
# service must use the SAME path so the workdir it records matches what the
# runner creates. Runs as root so it can write the mounted volume (the sandboxes
# are throwaway and already run Claude Code with permissions bypassed).
ENV HIVE_WORKSPACES_ROOT=/workspaces
RUN mkdir -p /workspaces
CMD ["node", "--experimental-strip-types", "packages/runner/src/index.ts"]
