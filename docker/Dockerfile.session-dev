# syntax=docker/dockerfile:1

# hive-session-dev — the default hosted-session image.
# Full development toolbox + headless GUI/browser stack so hosted Codex/Claude
# sessions can build, test, screenshot, and debug desktop/web apps inside their
# per-workspace containers.

FROM rust:bookworm AS rust-toolchain
RUN rustup component add rustfmt clippy

FROM mcr.microsoft.com/dotnet/sdk:9.0-bookworm-slim AS dotnet-toolchain

FROM node:22-bookworm-slim AS runtime
ENV DEBIAN_FRONTEND=noninteractive \
    NODE_ENV=development \
    DOTNET_CLI_TELEMETRY_OPTOUT=1 \
    DOTNET_ROOT=/usr/share/dotnet \
    CARGO_HOME=/usr/local/cargo \
    RUSTUP_HOME=/usr/local/rustup \
    PLAYWRIGHT_BROWSERS_PATH=/ms-playwright \
    PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1 \
    DISPLAY=:99 \
    HIVE_WORKSPACE=/workspace

# Core development, build, debugging, browser, and virtual-display packages.
RUN apt-get update && apt-get install -y --no-install-recommends \
      bash zsh fish sudo tini dumb-init \
      ca-certificates curl wget gnupg dirmngr openssh-client \
      git git-lfs procps psmisc htop less vim nano jq yq unzip zip xz-utils file tree ripgrep fd-find rsync \
      build-essential pkg-config cmake ninja-build make autoconf automake libtool \
      clang lldb gdb strace lsof netcat-openbsd dnsutils iproute2 iputils-ping \
      libssl-dev libsqlite3-dev sqlite3 postgresql-client redis-tools \
      python3 python3-pip python3-venv python3-dev pipx \
      openjdk-17-jdk maven gradle golang-go \
      chromium firefox-esr \
      xvfb xauth x11vnc novnc websockify fluxbox dbus-x11 xdg-utils \
      fonts-liberation fonts-noto fonts-noto-color-emoji fonts-dejavu \
      libnss3 libnspr4 libatk-bridge2.0-0 libatk1.0-0 libcups2 libdrm2 libxkbcommon0 libxcomposite1 libxdamage1 libxfixes3 libxrandr2 libgbm1 libasound2 libgtk-3-0 libgtk-4-1 libvulkan1 \
  && rm -rf /var/lib/apt/lists/*

# Rust + .NET copied from official images so the session image can build common
# backend/desktop stacks without bootstrapping toolchains on first use.
COPY --from=rust-toolchain /usr/local/cargo /usr/local/cargo
COPY --from=rust-toolchain /usr/local/rustup /usr/local/rustup
COPY --from=dotnet-toolchain /usr/share/dotnet /usr/share/dotnet
RUN ln -sf /usr/share/dotnet/dotnet /usr/bin/dotnet

# Node package managers, hosted-agent runtimes, and test runners.
RUN corepack enable && \
    npm install -g \
      typescript tsx vite vitest \
      @playwright/test playwright \
      selenium-webdriver webdriverio \
      @anthropic-ai/claude-code @openai/codex opencode-ai@latest && \
    python3 -m pip install --break-system-packages \
      uv pytest pytest-xdist pytest-playwright selenium robotframework requests pyjwt && \
    git lfs install --system

# Let Playwright users target distro browsers without downloading large managed
# browser archives. Projects that rely on Playwright's default cache can still run
# `playwright install` in their workspace.
ENV PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium \
    PLAYWRIGHT_FIREFOX_EXECUTABLE_PATH=/usr/bin/firefox-esr

COPY docker/session-dev-entrypoint.sh /usr/local/bin/session-dev-entrypoint
RUN chmod +x /usr/local/bin/session-dev-entrypoint && \
    mkdir -p /workspace /tmp/hive-gui /ms-playwright && \
    chmod 1777 /workspace /tmp/hive-gui /ms-playwright

WORKDIR /workspace
ENTRYPOINT ["/usr/bin/tini", "--", "session-dev-entrypoint"]
CMD ["tail", "-f", "/dev/null"]
