# syntax=docker/dockerfile:1

# hive-web — the Solid.js SPA, built with Vite and served by nginx. nginx also
# reverse-proxies the API surface (/api/*, the /api/stream SSE channel, and the
# /mcp Streamable-HTTP endpoint) to the hive-api service over the internal
# network, so the browser only ever talks to one origin (mirrors the Vite dev
# proxy in vite.config.ts).

# ----- build: produce packages/web/dist -----
FROM node:22-bookworm-slim AS build
RUN corepack enable
WORKDIR /app
RUN printf 'node-linker=hoisted\n' > .npmrc
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json ./
COPY packages/shared/package.json ./packages/shared/
COPY packages/api/package.json ./packages/api/
COPY packages/cli/package.json ./packages/cli/
COPY packages/web/package.json ./packages/web/
COPY packages/worker/package.json ./packages/worker/
RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    pnpm install --frozen-lockfile
COPY . .
RUN pnpm --filter @hive/shared build \
 && pnpm --filter @hive/web build

# ----- runtime: static SPA + API reverse proxy -----
FROM nginx:1.27-alpine AS runtime
RUN apk add --no-cache curl
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/packages/web/dist /usr/share/nginx/html
EXPOSE 8091
